    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                        "Warning",
        "Microsoft.Hosting.Lifetime":       "Information",
        "System":                           "Warning"
      }
    }
  },
  "AllowedHosts": "*",
